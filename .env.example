# Joomla shared credentials (used for all sites; only the URL changes per session)
JOOMLA_BASE_URL=https://your-default-site.example.com/administrator
JOOMLA_USERNAME=shannon
JOOMLA_PASSWORD=your-password-here

# Comma-separated list of module type titles to hide from the AI (case-insensitive).
# MODULE_TYPE_BLACKLIST=Breadcrumbs,Syndication Feeds,Who's Online

# Comma-separated list of menu item type titles to hide when creating new menu items (case-insensitive).
# Existing menu items of blacklisted types can still be read and edited by ID.
# MENU_ITEM_TYPE_BLACKLIST=System Links - Alias,System Links - Text Separator

# HTTP mode — set this to enable the network-accessible server.
# Omit or leave blank for local stdio mode (used by Claude Desktop direct config).
HTTP_PORT=3000

# Per-team-member access tokens — one entry per person.
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# To revoke access: remove that line and redeploy. No other tokens are affected.
MCP_TOKEN_JEREMY=replace-with-a-64-char-hex-string
MCP_TOKEN_ALICE=replace-with-a-different-64-char-hex-string
# MCP_TOKEN_BOB=...
# MCP_TOKEN_CAROL=...
